  m_Script: {fileID: 11500000, guid: 9abd9aea8a0bfd54d99b430b25791ec3, type: 3}
  m_Name: GasMan
  m_EditorClassIdentifier: Assembly-CSharp::DialogueAsset
  dialogueId: A_Intro
  nodes:
  - nodeId: A0
    text: "\uC548\uB155\uD558\uC138\uC694!"
    speakerId: "\uAC00\uC2A4\uB9E8"
    voice: {fileID: 8300000, guid: 8d2541962c18e6c4da975f532d3bfe1d, type: 3}
    autoAdvanceDelay: 0
    choices: []
    nextNodeId: A1
    onEnterEvent: 
    onExitEvent: 
  - nodeId: A1
    text: "\uC5EC\uAE30\uB294 \uD559\uC2B5\uAD00\uC785\uB2C8\uB2E4.\r\n\uC800 \uAC00\uC2A4\uB9E8\uC744
      \uB530\uB77C \uD559\uC2B5\uAD00\uC744 \uAD6C\uACBD\uD574 \uBCFC\uAE4C\uC694?"
    speakerId: "\uAC00\uC2A4\uB9E8"
    voice: {fileID: 8300000, guid: 93423a7caa3ce34498114408099dca70, type: 3}
    autoAdvanceDelay: 0
    choices: []
    nextNodeId: A2
    onEnterEvent: NPC_Explain
    onExitEvent: 
  - nodeId: A2
    text: "\uD568\uAED8 \uD559\uC2B5\uAD00 \uB0B4\uBD80\uB97C \uC0B4\uD3B4\uBCFC\uAC8C\uC694!\r\n\uC800\uB97C
      \uB530\uB77C\uC640 \uC8FC\uC138\uC694."
    speakerId: "\uC548\uC804\uC774"
    voice: {fileID: 8300000, guid: 0ec5c523cbdbad845a11dee0b7c46e43, type: 3}
    autoAdvanceDelay: 0
    choices: []
    nextNodeId: 
    onEnterEvent: NPC_Explain
    onExitEvent: NPC_START_GUIDE
  - nodeId: S0
    text: "\uC774\uACF3\uC5D0\uC11C\uB294 \uAC00\uC2A4\uC0AC\uACE0 \uC0C1\uD669\uBCC4
      \n\uB300\uC751\uC694\uB839\uC5D0 \uB300\uD574 \uC54C\uC544\uBCFC \uC218 \uC788\uC5B4\uC694."
    speakerId: "\uC548\uC804\uC774"
    voice: {fileID: 8300000, guid: 88affdc46d7f5ec4b97a30caa687e79a, type: 3}
    autoAdvanceDelay: 0
    choices: []
    nextNodeId: A3
    onEnterEvent: NPC_Explain
    onExitEvent: 
  - nodeId: A3
    text: "\uADF8\uB7FC, \uB2E4\uC74C\uC73C\uB85C \uC774\uB3D9\uD560\uAC8C\uC694."
    speakerId: "\uC548\uC804\uC774"
    voice: {fileID: 8300000, guid: 24fa3bc1556ea514eb1aa02375fd5090, type: 3}
    autoAdvanceDelay: 0
    choices: []
    nextNodeId: 
    onEnterEvent: NPC_Explain
    onExitEvent: NPC_START_GUIDE
  - nodeId: S1
    text: "\uC774\uACF3\uC5D0\uC11C\uB294 \uAC00\uC2A4 \uC548\uC804 \uC218\uCE59\uC5D0
      \uB300\uD55C \uC601\uC0C1\uC744 \uC2DC\uCCAD\uD560 \uC218 \uC788\uB2F5\uB2C8\uB2E4."
    speakerId: "\uC548\uC804\uC774"
    voice: {fileID: 8300000, guid: bb95b1f21d5e41d4ab2d2fce4d8ebd63, type: 3}
    autoAdvanceDelay: 0
    choices: []
    nextNodeId: A4
    onEnterEvent: NPC_Explain
    onExitEvent: 
  - nodeId: A4
    text: "\uC774\uC81C \uB9C8\uC9C0\uB9C9 \uC7A5\uC18C\uB85C \uC774\uB3D9\uD574
      \uBCFC\uAE4C\uC694?"
    speakerId: "\uC548\uC804\uC774"
    voice: {fileID: 8300000, guid: ac4c246e0ac6f8b4ebfac4b31ff27589, type: 3}
    autoAdvanceDelay: 0
    choices: []
    nextNodeId: 
    onEnterEvent: NPC_Explain
    onExitEvent: NPC_START_GUIDE
  - nodeId: S2
    text: "\uC774\uACF3\uC740 \uAC00\uC2A4 \uC0AC\uACE0 \uC2DC\uBBAC\uB808\uC774\uC158
      \uACF5\uAC04\uC785\uB2C8\uB2E4.\r\n\uC9C0\uAD6C\uBCF8\uC758 \uBC84\uD2BC\uC744
      \uB20C\uB7EC \uC2DC\uC791\uD560 \uC218 \uC788\uC5B4\uC694."
    speakerId: "\uC548\uC804\uC774"
    voice: {fileID: 8300000, guid: b58f2f78232beec4daf20cfc8e5d109d, type: 3}
    autoAdvanceDelay: 0
    choices: []
    nextNodeId: A5
    onEnterEvent: NPC_Explain
    onExitEvent: 
  - nodeId: A5
    text: "\uD559\uC2B5\uAD00\uC5D0 \uB300\uD574 \uC124\uBA85\uC740 \uB05D\uC774\uC5D0\uC694.\r\n\uC774\uC820
      \uC790\uC720\uB86D\uAC8C \uB458\uB7EC\uBCF4\uBA74\uC11C \uCCB4\uD5D8\uD574
      \uBCF4\uC138\uC694!"
    speakerId: "\uC548\uC804\uC774"
    voice: {fileID: 8300000, guid: f2fc50b903109b44da94404104e9f9ab, type: 3}
    autoAdvanceDelay: 0
    choices: []
    nextNodeId: 
    onEnterEvent: NPC_Explain
    onExitEvent: NPC_End_GUIDE
